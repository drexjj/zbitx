#!/bin/sh -e
# Note: the '-e' flag will make the script stop immediately upon error with 
# the error reflected in the environment.  This makes it easier for users to
# see which command caused the error.
F=$@
echo ">>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>"
date
cd $HOME/sbitx
git stash --include-untracked
git remote set-url origin https://github.com/drexjj/zbitx.git
git pull
git checkout main
cd $HOME/sbitx/src/ft8_lib
make
sudo make install
cd $HOME/sbitx
./build sbitx
echo "<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<"

echo "zbitx has been installed successfully. You can now close this window."
